{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ES2020",
    "moduleResolution": "Node",
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "outDir": "renderer",
    "rootDir": "renderer",
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "sourceMap": false,
    "types": []
  },
  "include": ["renderer/renderer.ts"],
  "exclude": ["node_modules"]
}
